<script>
  // ── 비밀번호 ──
  const PASSWORD = '6060';

  // ── 타이머 ──
  // ★ 여기서 마감일 설정 (페이지 공개일 + 14일)
  // 예: 공개일이 2026-05-10이면 → '2026-05-24T23:59:59+09:00'
  const DEADLINE = new Date('2026-05-24T23:59:59+09:00');

  function pad(n) { return String(n).padStart(2, '0'); }

  function timerTick() {
    const diff = DEADLINE - Date.now();
    const bar  = document.getElementById('bottom-timer');
    if (!bar) return;

    if (diff <= 0) {
      document.getElementById('bt-label').textContent = '';
      document.getElementById('bt-clock').innerHTML =
        '<span class="bt-expired">⚠ 예약 기간이 종료되었습니다</span>';
      const btn = document.getElementById('bt-btn');
      btn.classList.add('closed');
      btn.textContent = '마감';
      return;
    }

    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);

    document.getElementById('t-d').textContent = pad(d);
    document.getElementById('t-h').textContent = pad(h);
    document.getElementById('t-m').textContent = pad(m);
    document.getElementById('t-s').textContent = pad(s);

    setTimeout(timerTick, 1000);
  }

  function showTimer() {
    document.getElementById('bottom-timer').classList.add('show');
    timerTick();
    // 하단 여백 확보
    document.body.style.paddingBottom = '70px';
  }

  function checkPw() {
    const val = document.getElementById('pw-input').value;
    if (val === PASSWORD) {
      document.getElementById('lock-screen').classList.add('hidden');
      setTimeout(() => {
        document.getElementById('main').classList.add('visible');
        initReveal();
        showTimer();
      }, 800);
    } else {
      const err = document.getElementById('lock-error');
      err.textContent = '비밀번호가 맞지 않습니다';
      setTimeout(() => { err.textContent = ''; }, 2500);
      document.getElementById('pw-input').value = '';
    }
  }

  document.getElementById('pw-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') checkPw();
  });

  // ── 스크롤 리빌 ──
  function initReveal() {
    const els = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver(entries => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          e.target.style.transitionDelay = (i * 0.05) + 's';
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    els.forEach(el => io.observe(el));
  }

  function scrollToPricing() {
    document.getElementById('pricing').scrollIntoView({ behavior: 'smooth' });
  }
</script>
