<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>슬로우오션 — 재방문 전용 얼리버드</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Serif+KR:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0d1b2a;
    --deep: #152236;
    --ocean: #1a3a5c;
    --teal: #1e7fa0;
    --aqua: #4eb5c8;
    --gold: #c9a96e;
    --gold-light: #e8d5a3;
    --cream: #f5f0e8;
    --white: #ffffff;
    --muted: rgba(255,255,255,0.5);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'Noto Serif KR', serif;
    overflow-x: hidden;
  }

  /* ── 잠금 화면 ── */
  #lock-screen {
    position: fixed;
    inset: 0;
    background: var(--navy);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    transition: opacity 0.8s ease, visibility 0.8s ease;
  }
  #lock-screen.hidden { opacity: 0; visibility: hidden; }

  .lock-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.4em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .lock-sub {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin-bottom: 3.5rem;
  }

  .lock-wave {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 2.5rem;
  }

  .lock-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--cream);
    margin-bottom: 0.6rem;
    text-align: center;
  }
  .lock-desc {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .lock-input-wrap {
    position: relative;
    width: min(320px, 85vw);
    margin-bottom: 1rem;
  }
  .lock-input {
    width: 100%;
    padding: 1rem 1.2rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,169,110,0.3);
    border-radius: 2px;
    color: var(--white);
    font-family: 'Noto Serif KR', serif;
    font-size: 1rem;
    letter-spacing: 0.3em;
    text-align: center;
    outline: none;
    transition: border-color 0.3s;
  }
  .lock-input:focus { border-color: var(--gold); }
  .lock-input::placeholder { color: rgba(255,255,255,0.2); letter-spacing: 0.2em; font-size: 0.85rem; }

  .lock-btn {
    width: min(320px, 85vw);
    padding: 1rem;
    background: linear-gradient(135deg, var(--gold), #a87d45);
    border: none;
    border-radius: 2px;
    color: var(--navy);
    font-family: 'Noto Serif KR', serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    margin-bottom: 1rem;
  }
  .lock-btn:hover { opacity: 0.9; transform: translateY(-1px); }

  .lock-error {
    font-size: 0.75rem;
    color: #e07070;
    letter-spacing: 0.05em;
    height: 1.2em;
    transition: opacity 0.3s;
  }

  .lock-hint {
    position: absolute;
    bottom: 2rem;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.05em;
    text-align: center;
  }

  /* ── 메인 콘텐츠 ── */
  #main { opacity: 0; transition: opacity 1s ease; }
  #main.visible { opacity: 1; }

  /* 히어로 */
  .hero {
    min-height: 100svh;
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 110%, rgba(30,127,160,0.25) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(201,169,110,0.08) 0%, transparent 60%);
  }

  /* 물결 애니메이션 */
  .wave-bg {
    position: absolute;
    bottom: 0; left: -10%; right: -10%;
    height: 35%;
    opacity: 0.06;
  }
  .wave-path {
    animation: waveMove 8s ease-in-out infinite;
  }
  .wave-path:nth-child(2) { animation-delay: -3s; opacity: 0.5; }
  .wave-path:nth-child(3) { animation-delay: -5s; opacity: 0.3; }
  @keyframes waveMove {
    0%, 100% { d: path("M-200,80 Q0,20 200,80 Q400,140 600,80 Q800,20 1000,80 Q1200,140 1400,80 L1400,200 L-200,200 Z"); }
    50% { d: path("M-200,100 Q0,50 200,100 Q400,150 600,100 Q800,50 1000,100 Q1200,150 1400,100 L1400,200 L-200,200 Z"); }
  }

  .hero-inner { position: relative; text-align: center; max-width: 640px; }

  .badge {
    display: inline-block;
    padding: 0.35rem 1.2rem;
    border: 1px solid rgba(201,169,110,0.4);
    border-radius: 20px;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    color: var(--gold);
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s ease 0.2s both;
  }

  .hero-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(0.9rem, 2.5vw, 1.1rem);
    font-weight: 300;
    letter-spacing: 0.5em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    animation: fadeUp 0.8s ease 0.4s both;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
    animation: fadeUp 0.8s ease 0.5s both;
  }
  .hero-title em {
    font-style: italic;
    color: var(--aqua);
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 300;
    font-style: italic;
    color: var(--gold-light);
    margin-bottom: 2rem;
    animation: fadeUp 0.8s ease 0.6s both;
  }

  .divider {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 2rem;
    animation: fadeUp 0.8s ease 0.7s both;
  }

  .hero-desc {
    font-size: 0.85rem;
    line-height: 2;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.04em;
    margin-bottom: 3rem;
    animation: fadeUp 0.8s ease 0.8s both;
  }

  /* 할인 뱃지 */
  .discount-showcase {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    animation: fadeUp 0.8s ease 0.9s both;
    flex-wrap: wrap;
  }
  .disc-item {
    text-align: center;
  }
  .disc-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }
  .disc-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 600;
    line-height: 1;
    color: var(--white);
  }
  .disc-value.gold { color: var(--gold); }
  .disc-value.aqua { color: var(--aqua); }
  .disc-arrow {
    font-size: 1.5rem;
    color: var(--gold);
    opacity: 0.5;
  }
  .disc-plus {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .disc-plus-icon {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
  }
  .disc-plus-text {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--gold-light);
  }

  .cta-btn {
    display: inline-block;
    padding: 1.1rem 3rem;
    background: linear-gradient(135deg, var(--gold), #a87d45);
    color: var(--navy);
    font-family: 'Noto Serif KR', serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-decoration: none;
    border-radius: 2px;
    transition: transform 0.2s, box-shadow 0.2s;
    animation: fadeUp 0.8s ease 1s both;
    cursor: pointer;
    border: none;
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(201,169,110,0.3);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: fadeUp 0.8s ease 1.2s both;
  }
  .scroll-hint span { font-size: 0.62rem; letter-spacing: 0.2em; color: var(--muted); }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  /* ── 새로워진 섹션 ── */
  .section {
    padding: 5rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-tag {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.3;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .section-title em { font-style: italic; color: var(--aqua); }
  .section-lead {
    font-size: 0.83rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.9;
    letter-spacing: 0.04em;
    margin-bottom: 3rem;
  }

  /* 업그레이드 카드 */
  .upgrade-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5px;
    background: rgba(201,169,110,0.1);
    border: 1px solid rgba(201,169,110,0.1);
  }

  .upgrade-card {
    background: var(--deep);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .upgrade-card:hover { background: var(--ocean); }

  .upgrade-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .upgrade-card:hover::before { opacity: 1; }

  .upgrade-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem;
    font-weight: 300;
    color: rgba(201,169,110,0.15);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .upgrade-icon {
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
  }
  .upgrade-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
    color: var(--gold-light);
  }
  .upgrade-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    letter-spacing: 0.03em;
  }
  .upgrade-new {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.25rem 0.7rem;
    border: 1px solid rgba(78,181,200,0.4);
    border-radius: 20px;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--aqua);
  }

  /* ── 할인 구조 ── */
  .pricing-section {
    padding: 5rem 1.5rem;
    background: var(--deep);
  }
  .pricing-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .pricing-table {
    margin: 3rem 0;
    border: 1px solid rgba(201,169,110,0.15);
    overflow: hidden;
  }

  .pricing-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pricing-row:last-child { border-bottom: none; }
  .pricing-row.header {
    background: rgba(201,169,110,0.08);
  }
  .pricing-row.highlight {
    background: linear-gradient(135deg, rgba(30,127,160,0.15), rgba(201,169,110,0.08));
    position: relative;
  }
  .pricing-row.highlight::before {
    content: '재방문 전용';
    position: absolute;
    top: -10px; right: 1rem;
    padding: 0.2rem 0.8rem;
    background: var(--gold);
    color: var(--navy);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    font-weight: 600;
    border-radius: 20px;
  }

  .pricing-cell {
    padding: 1.2rem 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.6);
    border-right: 1px solid rgba(255,255,255,0.05);
  }
  .pricing-cell:last-child { border-right: none; }
  .pricing-row.header .pricing-cell {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--gold);
    font-weight: 600;
  }
  .pricing-cell.strong {
    color: var(--white);
    font-weight: 600;
  }
  .pricing-cell.accent {
    color: var(--gold);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .pricing-cell.aqua-accent {
    color: var(--aqua);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .pricing-note {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.8;
    letter-spacing: 0.03em;
    margin-top: 1.5rem;
  }

  /* ── 후기 ── */
  .review-section {
    padding: 5rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .review-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .review-card {
    background: var(--deep);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 2rem;
    position: relative;
  }
  .review-card::before {
    content: '"';
    position: absolute;
    top: 1rem; left: 1.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    color: rgba(201,169,110,0.15);
    line-height: 1;
  }
  .review-text {
    font-size: 0.78rem;
    line-height: 1.9;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.03em;
    margin-bottom: 1.2rem;
    position: relative;
  }
  .review-author {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--gold);
  }
  .review-stars {
    color: var(--gold);
    font-size: 0.7rem;
    margin-bottom: 0.3rem;
  }
  .review-platform {
    font-size: 0.62rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.1em;
    margin-top: 0.3rem;
  }

  /* ── 수치 ── */
  .stats-strip {
    background: var(--ocean);
    padding: 3.5rem 1.5rem;
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 600;
    color: var(--gold);
    display: block;
  }
  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.4);
    margin-top: 0.3rem;
  }

  /* ── 예약 CTA ── */
  .cta-section {
    padding: 6rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 50%, rgba(30,127,160,0.2) 0%, transparent 70%);
  }
  .cta-inner { position: relative; max-width: 560px; margin: 0 auto; }
  .cta-pretitle {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 300;
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .cta-title em { font-style: italic; color: var(--aqua); }
  .cta-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.9;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }

  .cta-btn-large {
    display: inline-block;
    padding: 1.3rem 4rem;
    background: linear-gradient(135deg, var(--gold), #a87d45);
    color: var(--navy);
    font-family: 'Noto Serif KR', serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-decoration: none;
    border-radius: 2px;
    cursor: pointer;
    border: none;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-bottom: 1.2rem;
  }
  .cta-btn-large:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 50px rgba(201,169,110,0.3);
  }

  .cta-caption {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.1em;
  }

  /* ── 푸터 ── */
  footer {
    padding: 2.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.5em;
    color: var(--gold);
    display: block;
    margin-bottom: 0.5rem;
  }
  .footer-note {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.08em;
    line-height: 1.8;
  }

  /* 애니메이션 */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* 반응형 */
  @media (max-width: 480px) {
    .discount-showcase { gap: 0.8rem; }
    .disc-arrow { display: none; }
    .stats-strip { gap: 2rem; }
    .pricing-cell { padding: 0.9rem 0.6rem; font-size: 0.72rem; }
  }
  /* ── 하단 타이머 바 ── */
  .bottom-timer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--deep);
    border-top: 1px solid rgba(201,169,110,0.2);
    z-index: 500;
    display: none; /* JS로 열림 */
  }
  .bottom-timer.show { display: block; }

  .bt-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0.75rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .bt-label {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    white-space: nowrap;
  }

  .bt-clock {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .bt-box {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(201,169,110,0.2);
    border-radius: 3px;
    padding: 0.25rem 0.45rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--white);
    min-width: 2.2rem;
    text-align: center;
    line-height: 1;
  }
  .bt-sep {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: var(--gold);
    opacity: 0.5;
  }
  .bt-unit {
    font-size: 0.55rem;
    color: rgba(255,255,255,0.3);
    margin-left: 0.1rem;
    margin-right: 0.3rem;
    letter-spacing: 0.05em;
  }

  .bt-reserve {
    padding: 0.55rem 1.4rem;
    background: linear-gradient(135deg, var(--gold), #a87d45);
